---
import { Image } from 'astro:assets';

const { post } = Astro.props;
const teaser = post.data.excerpt || post.data.description;
const categoryHref = post.data.category ? `/blog/category/${post.data.category}/` : null;
const postHref = `/blog/${post.id}/`;
---

<article class="blog-card">
  <div class="blog-card-shell">
    <div class="blog-card-media">
      {post.data.cover && (
        <Image
          src={post.data.cover}
          alt={post.data.coverAlt ?? post.data.title}
          class="blog-card-image"
          widths={[480, 720]}
          sizes="(max-width: 768px) 100vw, (max-width: 1200px) 50vw, 33vw"
        />
      )}

      {categoryHref && (
        <a href={categoryHref} class="blog-card-category">
          {post.data.category}
        </a>
      )}

      <a href={postHref} class="blog-card-overlay-link" aria-label={post.data.title}></a>
    </div>

    <div class="blog-card-body">
      <h2 class="blog-card-title">
        <a href={postHref} class="blog-card-title-link">{post.data.title}</a>
      </h2>
      <p class="blog-card-excerpt">{teaser}</p>
    </div>
  </div>
</article>

<style>
  .blog-card {
    min-width: 0;
  }

  .blog-card-shell {
    display: grid;
    grid-template-rows: auto 1fr;
    height: 100%;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 1rem;
    overflow: hidden;
    transition: transform 0.18s ease, border-color 0.18s ease, box-shadow 0.18s ease, background-color 0.18s ease;
  }

  .blog-card-shell:hover {
    transform: translateY(-3px);
    border-color: var(--accent);
    box-shadow: 0 18px 40px rgba(0, 0, 0, 0.12);
    background: var(--surface-2);
  }

  .blog-card-media {
    position: relative;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: var(--surface-2);
  }

  .blog-card-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .blog-card-overlay-link {
    position: absolute;
    inset: 0;
    z-index: 1;
  }


  .blog-card-category {
    position: absolute;
    top: 0.85rem;
    left: 0.85rem;
    z-index: 10;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2rem;
    padding: 0.45rem 0.75rem;
    border-radius: 999px;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: white;
    background: rgba(8, 20, 24, 0.78);
    backdrop-filter: blur(8px);
    text-decoration: none;
    pointer-events: auto;
  }

  .blog-card-category:hover {
    background: var(--accent);
    color: #071012;
  }

  .blog-card-body {
    display: grid;
    gap: 0.75rem;
    padding: 1rem 1rem 1.1rem;
    position: relative;
  }

  .blog-card-title {
    margin: 0;
    font-size: 1.08rem;
    line-height: 1.32;
    color: var(--text);
    position: relative;
    z-index: 2;
  }

  .blog-card-title-link {
    color: inherit;
    text-decoration: none;
  }

  .blog-card-title-link:hover {
    color: var(--accent-hover);
  }

  .blog-card-excerpt {
    margin: 0;
    color: var(--soft);
    font-size: 0.95rem;
    line-height: 1.55;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  :global([data-theme="light"] .blog-card-category) {
    color: #0f1417;
    background: rgba(255, 255, 255, 0.82);
  }

  :global([data-theme="light"] .blog-card-category:hover) {
    color: #071012;
    background: var(--accent);
  }
</style>