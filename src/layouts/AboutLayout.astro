---
import BaseLayout from './BaseLayout.astro';

const { frontmatter } = Astro.props;
---

<BaseLayout 
  title={frontmatter.title} 
  description={frontmatter.description}
  type="article"
>
  <article class="post">
    <div class="content">
      <slot />
    </div>

    <nav class="post-nav" aria-label="Navigasi">
      <a href="/" class="post-nav-card post-nav-prev">
        <span class="post-nav-label">Kembali ke</span>
        <strong>Home</strong>
      </a>

      <a href="/blog" class="post-nav-card post-nav-next">
        <span class="post-nav-label">Lihat semua</span>
        <strong>Blog</strong>
      </a>
    </nav>
  </article>
</BaseLayout>

<style>
  .post-nav {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid rgba(99, 216, 212, 0.1);
  }
  .post-nav-card {
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
    padding: 1rem 1.1rem;
    border-radius: 1rem;
    border: 1px solid rgba(99, 216, 212, 0.12);
    background: #151c20db;
    color: var(--text);
    text-decoration: none;
    transition: transform 0.18s ease, border-color 0.18s ease, background-color 0.18s ease;
  }
  .post-nav-card:hover {
    transform: translateY(-2px);
    border-color: #63d8d438;
    background: #1b252beb;
    color: var(--text);
  }
  .post-nav-label {
    font-size: 0.82rem;
    color: var(--soft);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .post-nav-card strong {
    line-height: 1.45;
    font-size: 1rem;
  }
  .post-nav-next {
    text-align: right;
    align-items: flex-end;
  }
  @media (max-width: 720px) {
    .post-nav {
      grid-template-columns: 1fr;
    }
    .post-nav-next {
      text-align: left;
      align-items: flex-start;
    }
  }
</style>
