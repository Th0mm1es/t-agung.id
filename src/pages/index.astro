---
import BaseLayout from '../layouts/BaseLayout.astro';
import BlogCard from '../components/BlogCard.astro';
import { getCollection } from 'astro:content';

let latestPosts = [];
let blogError = false;

try {
  latestPosts = (await getCollection('blog'))
    .filter((post) => post.data.draft !== true)
    .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
    .slice(0, 5);
} catch (error) {
  console.error('Failed to load blog collection:', error);
  blogError = true;
}
---

<BaseLayout
  title="Home"
  description="Blog tentang HMI, display engineering, touch, embedded electronics, dan eksperimen AI dalam bahasa Indonesia."
>
  <section class="hero-grid">
    <div class="hero-copy">
      <p class="eyebrow">Blog teknik untuk engineer muda</p>
      <h1>Catatan HMI, Display, dan Engineering untuk Engineer Muda</h1>
      <p class="lead">
        Blog ini membahas HMI, display engineering, touch, embedded electronics,
        dan sesekali eksperimen AI dari sudut pandang engineer yang suka
        membongkar hal teknis menjadi lebih jelas dan praktis.
      </p>
      <div class="hero-actions">
        <a class="button-primary" href="/blog">Lihat semua tulisan</a>
      </div>
    </div>

    <aside class="latest-posts latest-posts-cards" aria-labelledby="latest-posts-title">
      <div class="latest-posts-head">
        <h2 id="latest-posts-title">Tulisan terbaru</h2>
        <a class="latest-posts-link" href="/blog">Lihat semua</a>
      </div>

      {blogError ? (
        <p class="status-message">
          Blog belum bisa dimuat. Periksa <code>src/content.config.ts</code> dan
          frontmatter file di <code>src/content/blog</code>.
        </p>
      ) : latestPosts.length > 0 ? (
        <div class="latest-posts-grid">
          {latestPosts.map((post) => <BlogCard post={post} />)}
        </div>
      ) : (
        <p class="status-message">
          Belum ada tulisan yang tampil. Tambahkan minimal satu post valid di
          <code>src/content/blog</code>.
        </p>
      )}
    </aside>
  </section>

  <section>
    <a href="/about_me" class="about-author" aria-label="Tentang penulis">
      <div class="section-heading">
        <h2>Tentang penulis</h2>
        <p>
          Saya Thomas Agung. Saya menulis tentang HMI dan display engineering,
          terutama hal-hal praktis yang sering tidak dijelaskan dengan sederhana:
          trade-off desain, testing, integrasi, dan pelajaran dari proyek nyata.
        </p>
      </div>
    </a>
  </section>

  <section class="focus-grid" aria-label="Fokus utama blog">
    <a class="focus-card" href="/blog">
      <h2>HMI & display engineering</h2>
      <p>
        Catatan tentang arsitektur display, optical stack, touch, kualitas visual,
        dan keputusan desain yang sering muncul di proyek nyata.
      </p>
    </a>

    <a class="focus-card" href="/blog">
      <h2>Embedded & electronics</h2>
      <p>
        Pembahasan praktis seputar integrasi hardware, eksperimen elektronik,
        debugging, dan pendekatan engineering yang bisa langsung dipakai.
      </p>
    </a>

    <a class="focus-card" href="/blog">
      <h2>AI hobby & catatan karier</h2>
      <p>
        Sesekali saya juga menulis tentang AI lokal, alat bantu kerja engineer,
        dan refleksi profesional dari pengalaman kerja lintas lingkungan.
      </p>
    </a>
  </section>
</BaseLayout>

<style>
  :global(:root) {
    --bg: #0f1417;
    --surface: #151c20;
    --surface-2: #1b252b;
    --text: #e8f3f2;
    --muted: #9fb3b6;
    --line: rgba(99, 216, 212, 0.14);
    --accent: #2aa9a6;
    --accent-hover: #63d8d4;
    --highlight: #e3b341;
    --max: 1180px;
  }

  :global(body) {
    background: radial-gradient(circle at top, rgba(42, 169, 166, 0.08), transparent 28%),
      var(--bg);
    color: var(--text);
  }

  section {
    width: min(var(--max), calc(100% - 2rem));
    margin: 0 auto;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: 2rem;
    padding: 4rem 0 2.5rem;
    align-items: start;
  }

  .hero-copy {
    padding: 1rem 0;
  }

  .eyebrow {
    margin: 0 0 0.8rem;
    color: var(--highlight);
    font-size: 0.9rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  h1 {
    margin: 0 0 1rem;
    font-size: clamp(2.2rem, 5vw, 4.4rem);
    line-height: 1.05;
    max-width: 12ch;
  }

  .lead {
    margin: 0 0 1.5rem;
    max-width: 62ch;
    font-size: 1.05rem;
    line-height: 1.8;
    color: var(--muted);
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .button-primary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.9rem 1.2rem;
    border-radius: 0.9rem;
    background: var(--accent);
    color: #071012;
    text-decoration: none;
    font-weight: 600;
    transition: 180ms ease;
  }

  .button-primary:hover {
    background: var(--accent-hover);
  }

  .latest-posts,
  .focus-card,
  .about-author {
    background: rgba(21, 28, 32, 0.82);
    border: 1px solid var(--line);
    border-radius: 1.25rem;
    backdrop-filter: blur(8px);
  }

  .latest-posts {
    padding: 1.25rem;
  }

  .latest-posts-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .latest-posts h2,
  .about-author h2,
  .focus-card h2 {
    margin: 0;
    font-size: 1.05rem;
  }

  .latest-posts-link {
    color: var(--accent);
    font-size: 0.92rem;
    text-decoration: none;
  }

  .latest-posts-link:hover {
    color: var(--accent-hover);
  }

  .latest-posts-grid {
    display: grid;
    gap: 1rem;
  }

  .status-message {
    margin: 0;
    color: var(--muted);
    line-height: 1.7;
    font-size: 0.96rem;
  }

  .status-message code {
    color: var(--highlight);
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
  }

  .about-author {
    display: block;
    padding: 1.4rem;
    margin-bottom: 1.5rem;
    text-decoration: none;
    color: inherit;
    transition: transform 180ms ease, border-color 180ms ease, background-color 180ms ease;
  }

  .about-author:hover {
    transform: translateY(-2px);
    border-color: rgba(99, 216, 212, 0.22);
    background: rgba(27, 37, 43, 0.92);
  }

  .section-heading p {
    margin: 0;
    color: var(--muted);
    max-width: 72ch;
    line-height: 1.8;
  }

  .focus-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    padding-bottom: 4rem;
  }

  .focus-card {
    display: block;
    padding: 1.25rem;
    color: inherit;
    text-decoration: none;
    transition: transform 180ms ease, border-color 180ms ease, background-color 180ms ease;
  }

  .focus-card:hover {
    transform: translateY(-2px);
    border-color: rgba(99, 216, 212, 0.22);
    background: rgba(27, 37, 43, 0.92);
  }

  .focus-card h2 {
    color: var(--text);
  }

  .focus-card p {
    margin: 0;
    color: var(--muted);
    line-height: 1.75;
  }

  @media (max-width: 920px) {
    .hero-grid,
    .focus-grid {
      grid-template-columns: 1fr;
    }

    .hero-grid {
      padding-top: 2.5rem;
    }

    h1 {
      max-width: 100%;
    }
  }
</style>