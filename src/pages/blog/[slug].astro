---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);

  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post, posts },
  }));
}

const { post, posts } = Astro.props;
const { Content } = await render(post);

const currentIndex = posts.findIndex((item) => item.id === post.id);
const previousPost = currentIndex < posts.length - 1 ? posts[currentIndex + 1] : null;
const nextPost = currentIndex > 0 ? posts[currentIndex - 1] : null;

const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": post.data.title,
  "description": post.data.description,
  "datePublished": new Date(post.data.pubDate).toISOString(),
  "author": [{
    "@type": "Person",
    "name": "T. Agung",
    "url": "https://t-agung.id"
  }]
});
---

<BaseLayout 
  title={post.data.title} 
  description={post.data.description}
  type="article"
  image={post.data.cover?.src}
  schema={schema}
>
  <article class="post">
    <a href="/blog" class="back-link">← Kembali ke Blog</a>

    <header class="post-header">
      <h1>{post.data.title}</h1>
      <p class="post-meta">
        {new Date(post.data.pubDate).toLocaleDateString('id-ID', {
          year: 'numeric',
          month: 'long',
          day: 'numeric',
        })}
      </p>
    </header>

    {post.data.cover && (
      <img
        src={post.data.cover.src}
        width={post.data.cover.width}
        height={post.data.cover.height}
        alt={post.data.coverAlt ?? post.data.title}
      />
    )}

    <Content />

    <nav class="post-nav" aria-label="Navigasi tulisan">
      <a
        href={previousPost ? `/blog/${previousPost.id}/` : '/blog'}
        class="post-nav-card post-nav-prev"
      >
        <span class="post-nav-label">{previousPost ? 'Tulisan sebelumnya' : 'Navigasi'}</span>
        <strong>{previousPost ? previousPost.data.title : 'Semua artikel'}</strong>
      </a>

      <a
        href={nextPost ? `/blog/${nextPost.id}/` : '/'}
        class="post-nav-card post-nav-next"
      >
        <span class="post-nav-label">{nextPost ? 'Tulisan selanjutnya' : 'Navigasi'}</span>
        <strong>{nextPost ? nextPost.data.title : 'Home'}</strong>
      </a>
    </nav>
  </article>
</BaseLayout>

<style>
  .post-nav {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid rgba(99, 216, 212, 0.1);
  }
  .post-nav-card {
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
    padding: 1rem 1.1rem;
    border-radius: 1rem;
    border: 1px solid rgba(99, 216, 212, 0.12);
    background: #151c20db;
    color: var(--text);
    text-decoration: none;
    transition: transform 0.18s ease, border-color 0.18s ease, background-color 0.18s ease;
  }
  .post-nav-card:hover {
    transform: translateY(-2px);
    border-color: #63d8d438;
    background: #1b252beb;
    color: var(--text);
  }
  .post-nav-label {
    font-size: 0.82rem;
    color: var(--soft);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .post-nav-card strong {
    line-height: 1.45;
    font-size: 1rem;
  }
  .post-nav-next {
    text-align: right;
    align-items: flex-end;
  }
  @media (max-width: 720px) {
    .post-nav {
      grid-template-columns: 1fr;
    }
    .post-nav-next {
      text-align: left;
      align-items: flex-start;
    }
  }
</style>