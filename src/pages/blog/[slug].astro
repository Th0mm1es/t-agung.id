---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Comments from '../../components/Comments.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  posts.sort((a, b) => new Date(b.data.pubDate).valueOf() - new Date(a.data.pubDate).valueOf());

  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post, posts },
  }));
}

const { post, posts } = Astro.props;
const { Content, headings } = await render(post);

const currentIndex = posts.findIndex((item) => item.id === post.id);
const previousPost = currentIndex < posts.length - 1 ? posts[currentIndex + 1] : null;
const nextPost = currentIndex > 0 ? posts[currentIndex - 1] : null;

const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": post.data.title,
  "description": post.data.description,
  "datePublished": new Date(post.data.pubDate).toISOString(),
  "author": [{
    "@type": "Person",
    "name": "T. Agung",
    "url": "https://t-agung.id"
  }]
});
---

<BaseLayout 
  title={post.data.title} 
  description={post.data.description}
  type="article"
  image={post.data.cover?.src}
  schema={schema}
>
  <article class="post">
    <div class="post-content-wrapper">
      <a href="/blog" class="back-link">← Kembali ke Blog</a>

      <header class="post-header">
        <h1>{post.data.title}</h1>
        <p class="post-meta">
          {new Date(post.data.pubDate).toLocaleDateString('id-ID', {
            year: 'numeric',
            month: 'long',
            day: 'numeric',
          })}
        </p>
      </header>


      <Content />

      <nav class="post-nav" aria-label="Navigasi tulisan">
        <a
          href={previousPost ? `/blog/${previousPost.id}/` : '/blog'}
          class="post-nav-card post-nav-prev"
        >
          <span class="post-nav-label">{previousPost ? 'Tulisan sebelumnya' : 'Navigasi'}</span>
          <strong>{previousPost ? previousPost.data.title : 'Semua artikel'}</strong>
        </a>

        <a
          href={nextPost ? `/blog/${nextPost.id}/` : '/blog'}
          class="post-nav-card post-nav-next"
        >
          <span class="post-nav-label">{nextPost ? 'Tulisan selanjutnya' : 'Navigasi'}</span>
          <strong>{nextPost ? nextPost.data.title : 'Semua artikel'}</strong>
        </a>
      </nav>

      <Comments
        projectId="5701935021686784-proj"
        boxId={`comments-${post.id}`}
      />
    </div>

    <aside class="toc-sidebar">
      <div class="toc-sticky-container">
        <h2>On this page</h2>
        <nav aria-label="Table of contents">
          <ul>
            {headings
              .filter((heading) => heading.depth <= 3)
              .map((heading) => (
                <li class={`toc-depth-${heading.depth}`}>
                  <a href={`#${heading.slug}`}>{heading.text}</a>
                </li>
              ))}
          </ul>
        </nav>
      </div>
    </aside>
  </article>
</BaseLayout>

<style>
  /* FAIL-SAFE OVERFLOW UNBLOCK PATTERNS */
  :global(html), :global(body) {
    overflow-x: visible !important;
  }
  :global(main), :global(#main-content), :global(.shell) {
    overflow: visible !important;
    display: block !important;
  }

  /* Grid Layout Setup */
  .post {
    display: grid !important;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    width: 100%;
    align-items: start !important;
  }

  .post-nav {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid rgba(99, 216, 212, 0.1);
  }
  .post-nav-card {
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
    padding: 1rem 1.1rem;
    border-radius: 1rem;
    border: 1px solid rgba(99, 216, 212, 0.12);
    background: #151c20db;
    color: var(--text);
    text-decoration: none;
    transition: transform 0.18s ease, border-color 0.18s ease, background-color 0.18s ease;
  }
  .post-nav-card:hover {
    transform: translateY(-2px);
    border-color: #63d8d438;
    background: #1b252beb;
    color: var(--text);
  }
  .post-nav-label {
    font-size: 0.82rem;
    color: var(--soft);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .post-nav-card strong {
    line-height: 1.45;
    font-size: 1rem;
  }
  .post-nav-next {
    text-align: right;
    align-items: flex-end;
  }

  /* Pinned Table of Contents Sidebar Styles */
  .toc-sidebar {
    display: none;
  }

  @media (min-width: 1024px) {
    .post {
      grid-template-columns: minmax(0, var(--container-read)) 260px !important;
    }
    .toc-sidebar {
      display: block !important;
      position: sticky !important;
      top: 6.5rem !important; /* Locks sidebar right under your sticky top menu bar */
      max-height: calc(100vh - 8rem);
      align-self: start !important;
    }
    .toc-sticky-container {
      padding-left: 0.75rem;
      border-left: 1px solid rgba(99, 216, 212, 0.08);
      overflow-y: auto;
    }
    .toc-sidebar h2 {
      font-size: 0.72rem;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--soft);
      margin: 0 0 0.8rem 0;
    }
    .toc-sidebar ul {
      list-style: none;
      padding: 0;
      margin: 0;
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }
    .toc-sidebar a {
      font-size: 0.82rem;
      color: var(--muted);
      line-height: 1.4;
      display: block;
      padding: 0.1rem 0;
      transition: color 0.15s, padding-left 0.15s;
    }
    .toc-sidebar a:hover,
    .toc-sidebar a.active {
      color: var(--accent-hover);
    }
    .toc-sidebar a.active {
      font-weight: 500;
      border-left: 2px solid var(--accent);
      padding-left: 0.4rem;
      margin-left: -0.75rem;
    }
    .toc-depth-3 {
      padding-left: 0.85rem;
    }
  }

  @media (max-width: 720px) {
    .post-nav {
      grid-template-columns: 1fr;
    }
    .post-nav-next {
      text-align: left;
      align-items: flex-start;
    }
  }
</style>

<script>
  const initToc = () => {
    const observerOptions = {
      root: null,
      rootMargin: '-100px 0px -70% 0px',
      threshold: 0
    };

    const headings = Array.from(document.querySelectorAll('.post-content-wrapper h2, .post-content-wrapper h3'));
    const tocLinks = document.querySelectorAll('.toc-sidebar a');

    if (headings.length === 0 || tocLinks.length === 0) return;

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const id = entry.target.getAttribute('id');
          tocLinks.forEach((link) => link.classList.remove('active'));
          const activeLink = document.querySelector(`.toc-sidebar a[href="#${id}"]`);
          if (activeLink) {
            activeLink.classList.add('active');
          }
        }
      });
    }, observerOptions);

    headings.forEach((heading) => observer.observe(heading));
  };

  // Runs on initial page load and handles Astro view transitions cleanly if enabled
  document.addEventListener('DOMContentLoaded', initToc);
  document.addEventListener('astro:page-load', initToc);
</script>