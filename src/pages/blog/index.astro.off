---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogCard from '../../components/BlogCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout
  title="Blog"
  description="Kumpulan tulisan tentang HMI, display engineering, embedded electronics, dan eksperimen AI."
>
  <section>
    <div class="page-intro">
      <h1>Blog</h1>
      <p>
        Kumpulan tulisan tentang HMI, display engineering, embedded electronics,
        dan eksperimen teknis yang ditulis dari sudut pandang praktis.
      </p>
    </div>

    <div class="post-list">
      {posts.map((post) => <BlogCard post={post} />)}
    </div>
  </section>
</BaseLayout>